# # вставить свои api ключи
# ANTHROPIC_API_KEY=sk-ant-api...
# # HuggingFace token (опционально, для приватных/gated моделей)
# HF_TOKEN=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/hr_goals
CHROMA_PERSIST_DIR=./chroma_data
EMBEDDING_MODEL=BAAI/bge-m3
USE_RERANKER=false
# USE_RERANKER=true  # включить reranker BAAI/bge-reranker-v2-m3 (требует --build)
LLM_PROVIDER=azure_openai # anthropic | azure_openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE_EVAL=0
LLM_TEMPERATURE_GEN=0.3
LOG_LEVEL=INFO
