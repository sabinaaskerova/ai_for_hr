# --- Общие настройки (их менять не нужно) -------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/hr_goals
CHROMA_PERSIST_DIR=./chroma_data
HACKATHON_DATA_DIR=../hackathon_db   # путь до папки с CSV хакатона
EMBEDDING_MODEL=BAAI/bge-m3          # влияет на название коллекции Chroma
HF_TOKEN=                            # опционально, если модель эмбеддингов приватная
USE_RERANKER=false
LLM_TEMPERATURE_EVAL=0
LLM_TEMPERATURE_GEN=0.3
LOG_LEVEL=INFO

# --- Выбор провайдера LLM -----------------------------------------------------
# Вариант 1. Anthropic (проще, если есть только один ключ)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-20250514

# Вариант 2. Azure OpenAI 
LLM_PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<name>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
LLM_MODEL=gpt-4o
